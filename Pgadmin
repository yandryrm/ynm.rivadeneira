TABLAS DEL PGADMIN

--tabla para el Lunes
CREATE TABLE lunes (
    id SERIAL PRIMARY KEY,
    actividad VARCHAR(150) NOT NULL
);

--tabla para el Martes
CREATE TABLE martes (
    id SERIAL PRIMARY KEY,
    actividad VARCHAR(150) NOT NULL
);

-- tabla para el Miércoles
CREATE TABLE miercoles (
    id SERIAL PRIMARY KEY,
    actividad VARCHAR(150) NOT NULL
);

-- tabla para el Jueves
CREATE TABLE jueves (
    id SERIAL PRIMARY KEY,
    actividad VARCHAR(150) NOT NULL,
    observacion VARCHAR(250)
);

